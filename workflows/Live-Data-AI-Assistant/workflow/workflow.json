    {
      "parameters": {
        "jsCode": "const rawText = $input.first().json.content.parts[0].text;\n\nconst cleanedText = rawText.replace(/```json/gi, '').replace(/```/g, '').trim();\n\nlet parsed;\ntry {\n  parsed = JSON.parse(cleanedText);\n} catch (error) {\n  parsed = { route: \"GENERAL\", category: \"NONE\" };\n}\n\nconst originalData = $('Extract User Query').first().json;\n\nreturn [\n  {\n    json: {\n      user_query: originalData.user_query,\n      chat_id: originalData.chat_id,\n      user_first_name: originalData.user_first_name,\n      route: parsed.route || \"GENERAL\",\n      category: parsed.category || \"NONE\"\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
