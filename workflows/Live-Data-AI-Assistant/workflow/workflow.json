          "cachedResultName": "models/gemini-2.5-flash"
        },
        "messages": {
          "values": [
            {
              "content": "=You are a helpful assistant summarizing live search results for a Telegram chat. The user asked: \"{{ $json.user_query }}\". Below is structured data from a live search (title, description, source, url for each result). Write a clear, concise, friendly summary answering their question, mentioning 2-4 key points from the results. Keep it readable for a chat message, not overly long. Do not just list the raw data - synthesize it into a natural answer. At the end, you may mention 1-2 source names if relevant. Structured data: {{ JSON.stringify($json.structured_data) }}"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1.2,
      "position": [
        1456,
        -208
      ],
      "id": "210eebb1-ba87-4500-94c1-582444768bb9",
      "name": "Gemini Summary",
      "credentials": {
        "googlePalmApi": {
          "id": "KkPIlRb74u2HCNnN",
          "name": "Google Gemini(PaLM) Api account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const summaryText = $input.first().json.content.parts[0].text;\nconst originalData = $('Format Structured JSON').first().json;\n\nconst sourceTitles = originalData.structured_data\n  .map(item => item.source)\n  .join(\", \");\n\nreturn [\n  {\n    json: {\n      timestamp: new Date().toISOString(),\n      user_query: originalData.user_query,\n      chat_id: originalData.chat_id,\n      category: originalData.category,\n      route: originalData.route,\n      summary: `Sources: ${sourceTitles}`,\n      final_response: summaryText.trim().replace(/[*_`]/g, \"\"),\n      status: \"SUCCESS\"\n    }\n  }\n];"
      },
