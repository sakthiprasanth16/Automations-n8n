      "parameters": {
        "jsCode": "const answerText = $input.first().json.content.parts[0].text;\nconst originalData = $('Parse Classifier Output').first().json;\n\nreturn [\n  {\n    json: {\n      timestamp: new Date().toISOString(),\n      user_query: originalData.user_query,\n      chat_id: originalData.chat_id,\n      category: originalData.category,\n      route: originalData.route,\n      summary: \"N/A (General Query)\",\n      final_response: answerText.trim().replace(/[*_`]/g, \"\"),\n      status: \"SUCCESS\"\n    }\n  }\n];"
      },
