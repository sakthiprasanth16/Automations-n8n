    {
      "parameters": {
        "jsCode": "// Get the raw organicResults array from Apify's output\nconst rawResults = $input.first().json.organicResults || [];\n\n// Pull original context (user query, chat_id, route, category) from Parse Classifier Output\nconst originalData = $('Parse Classifier Output').first().json;\n\n// Convert into clean structured objects, limit to top 5\nconst structuredResults = rawResults.slice(0, 5).map(item => {\n  return {\n    title: item.title || \"No title\",\n    description: item.description || \"No description available\",\n    source: item.websiteTitle || \"Unknown source\",\n    url: item.url || \"\",\n    date: item.date || \"N/A\"\n  };\n});\n\nreturn [\n  {\n    json: {\n      user_query: originalData.user_query,\n      chat_id: originalData.chat_id,\n      route: originalData.route,\n      category: originalData.category,\n      structured_data: structuredResults\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1248,
        -208
      ],
      "id": "680c52a4-83be-458d-bc68-e42f9493a9c2",
      "name": "Format Structured JSON"
    },
    {
      "parameters": {
        "modelId": {
