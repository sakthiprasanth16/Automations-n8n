        "messages": {
          "values": [
            {
              "content": "=You are a strict classifier for a live-data assistant. Respond with ONLY a valid JSON object, nothing else, no markdown, no backticks. The JSON must have exactly two fields: \"route\" and \"category\". \"route\" must be either \"LIVE\" or \"GENERAL\". \"category\" must be one of: NEWS, PRICE, JOBS, STOCK, SEARCH, TECH, GITHUB, WEATHER (only if route is LIVE), or NONE (if route is GENERAL). Use LIVE only if the query needs current or real-time information such as news, prices, jobs, stocks, weather, or trending repos. Use GENERAL for conceptual, educational, or knowledge questions. User query: \"{{ $json.user_query }}\""
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1.2,
