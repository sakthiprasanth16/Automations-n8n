    {
      "parameters": {
        "jsCode": "const chatId = $('Extract Question').item.json.chatId;\nconst question = $('Extract Question').item.json.question;\nconst resp = items[0].json;\nlet answer = resp.output || resp.text || 'I could not find relevant information in the knowledge base.';\nanswer = String(answer).trim();\n\nif (!/^answer:/i.test(answer) && answer !== 'I could not find relevant information in the knowledge base.') {\n  answer = `Answer:\\n${answer}\\n\\nSources:\\n- (see retrieved context)`;\n}\n\n// Strip Markdown/LaTeX-style characters that break Telegram's message parser\nanswer = answer\n  .replace(/\\*/g, '')                // remove ALL asterisks (bold, italic, bullets)\n  .replace(/\\$/g, '')                 // remove ALL dollar signs (math wrapping)\n  .replace(/_/g, ' ')                 // replace underscores (e.g. d_model) with spaces\n  .replace(/`/g, \"'\")                 // replace backticks with plain quotes\n  .replace(/^-\\s+/gm, '• ');          // turn markdown \"- \" bullets into plain \"• \" bullets\n\n// Pull the real sources straight out of the Answer/Sources structure itself\nconst sourcesMatch = answer.match(/Sources:\\s*([\\s\\S]*)$/i);\nconst retrievedChunkIds = sourcesMatch ? sourcesMatch[1].trim() : '(no sources returned)';\n\n// Keep the tool's synthesized summary for logging context\nconst steps = resp.intermediateSteps || [];\nlet retrievedSummary = '(no tool call made)';\n\nif (steps.length > 0) {\n  const obs = steps[0].observation || '';\n  try {\n    const parsed = JSON.parse(obs);\n    retrievedSummary = (parsed[0] && parsed[0].response ? parsed[0].response : obs).slice(0, 300);\n  } catch (e) {\n    retrievedSummary = String(obs).slice(0, 300);\n  }\n}\n\nreturn [{\n  json: {\n    chatId,\n    question,\n    finalAnswer: answer,\n    retrievedSummary,\n    retrievedChunkIds\n  }\n}];"
      },
