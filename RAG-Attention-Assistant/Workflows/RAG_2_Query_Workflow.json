        "jsCode": "const chatId = $('Extract Question').item.json.chatId;\nconst question = $('Extract Question').item.json.question;\nconst errorMsg = (items[0].json.error && items[0].json.error.message) || 'Unknown error';\n\nconsole.log('AI Agent failed:', errorMsg);\n\nreturn [{\n  json: {\n    chatId,\n    question,\n    finalAnswer: 'Sorry, the AI service is temporarily unavailable. Please try again in a moment.',\n    retrievedSummary: `(service error: ${errorMsg})`,\n    retrievedChunkIds: '(error - no retrieval performed)'\n  }\n}];"
